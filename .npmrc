# Store do pnpm dentro do projeto (evita permissão em ~/.pnpm-store)
store-dir=.pnpm-store
# Expo/React Native: hoist completo para Metro e resolução de módulos (recomendado em monorepos)
node-linker=hoisted
# Prisma e Nest no monorepo (hoist só esses para build Vercel)
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=.prisma
public-hoist-pattern[]=@nestjs/config
# Expo/Metro: resolver pacotes no monorepo pnpm
public-hoist-pattern[]=@expo/metro-runtime
public-hoist-pattern[]=@expo/vector-icons
