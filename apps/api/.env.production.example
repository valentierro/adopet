# Copie para .env.production e preencha com os valores de PROD (Production na Vercel).
# A API carrega .env e depois .env.production quando NODE_ENV=production.
# Útil para testar localmente contra a base/recursos de produção (cuidado: não rode seeds destrutivos).
# Não commite .env.production (contém segredos).

DATABASE_URL="postgresql://...neon-prod...?sslmode=require&connection_limit=30&pool_timeout=20"
JWT_SECRET="segredo-de-producao"
S3_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
S3_REGION="us-east-005"
S3_BUCKET="adopet"
S3_ACCESS_KEY="keyID-prod"
S3_SECRET_KEY="applicationKey-prod"
S3_PUBLIC_BASE="https://s3.us-east-005.backblazeb2.com/adopet"
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Demais variáveis iguais aos da Vercel Production.
