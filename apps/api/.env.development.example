# Copie para .env.development e preencha com os valores de DEV (Pre-Production na Vercel).
# A API carrega .env e depois .env.development (este sobrescreve). Usado ao rodar a API localmente para desenvolvimento.
# Não commite .env.development (contém segredos).

DATABASE_URL="postgresql://...neon-dev...?sslmode=require&connection_limit=30&pool_timeout=20"
JWT_SECRET="segredo-diferente-do-prod"
S3_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
S3_REGION="us-east-005"
S3_BUCKET="adopet-dev"
S3_ACCESS_KEY="keyID-da-application-key-dev"
S3_SECRET_KEY="applicationKey-dev"
S3_PUBLIC_BASE="https://s3.us-east-005.backblazeb2.com/adopet-dev"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..." 
# Demais variáveis (CORS_ORIGINS, ADMIN_USER_IDS, SMTP, etc.) podem vir do .env ou repetir aqui.
