PORT=3000

# App mobile — versão mínima e última (modal "Atualize o app" no app publicado).
# Obrigatório em produção se app-version.json não estiver acessível no deploy.
# APP_LATEST_VERSION="1.0.35"
# APP_MIN_SUPPORTED_VERSION="1.0.34"

# Postgres local (Docker)
# DATABASE_URL="postgresql://adopet:adopet@localhost:5432/adopet?connection_limit=30&pool_timeout=20"

# Neon (https://neon.tech) — use a connection string do dashboard
# connection_limit e pool_timeout evitam "Timed out fetching a new connection" quando há muitas requisições simultâneas (ex.: mobile abrindo várias APIs em paralelo)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connection_limit=30&pool_timeout=20"

REDIS_URL="redis://localhost:6379"

# JWT (obrigatório em produção)
JWT_SECRET="change-me-in-production"

# Recuperação de senha: SMTP (Hostinger ou outro) e URL base do link no e-mail
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT=465
# SMTP_USER="contato@appadopet.com.br"
# SMTP_PASS="sua-senha-do-email"
# EMAIL_FROM="contato@appadopet.com.br"
# APP_URL="https://appadopet.com.br"  (usado para links e, se LOGO_URL não estiver definido, para logo em e-mails e páginas de confirmação)
# API_PUBLIC_URL="https://sua-api.vercel.app"  (URL pública da API; usada no link de confirmação do e-mail de recuperação de senha)
# LOGO_URL="https://appadopet.com.br/logo.png"  (URL absoluta da logo; domínio correto: appadopet.com.br; se não definir, usa APP_URL + '/logo.png')

# CORS — origens permitidas (separadas por vírgula). Necessário para o painel admin e para o app web.
# Ex.: CORS_ORIGINS="https://admin.appadopet.com.br,https://appadopet.com.br"
# Se não definir, todas as origens são permitidas (útil em dev).
# CORS_ORIGINS="https://admin.appadopet.com.br"

# Admin: IDs dos usuários que veem o link "Administração" no app (separados por vírgula).
# O seed cria o usuário admin-teste@adopet.com.br com este ID fixo — use para testar:
ADMIN_USER_IDS="22222222-2222-2222-2222-222222222222"

# S3-compatible storage — obrigatório para upload de fotos de pets
# Opção 1: MinIO local — subir: docker compose -f infra/docker-compose.yml --profile with-minio up -d
#          Criar bucket "adopet" no console http://localhost:9001 (minioadmin / minioadmin)
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_BUCKET="adopet"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_PUBLIC_BASE="http://localhost:9000/adopet"
#
# Opção 2: AWS S3 — use as credenciais do IAM e o nome do bucket
# S3_BUCKET="seu-bucket"
# S3_ACCESS_KEY="..."
# S3_SECRET_KEY="..."
# S3_PUBLIC_BASE="https://seu-bucket.s3.regiao.amazonaws.com"

# Stripe — obrigatório para parceiros comerciais (checkout e portal de assinatura)
# Crie um produto/price no dashboard Stripe e use o Price ID (ex: price_xxx)
# STRIPE_SECRET_KEY="sk_test_..."   # ou sk_live_... em produção
# STRIPE_WEBHOOK_SECRET="whsec_..."   # signing secret do webhook em modo Live (produção)
# STRIPE_WEBHOOK_SECRET_SANDBOX="whsec_..."   # signing secret do webhook em modo Test (sandbox); usado quando STRIPE_SECRET_KEY é sk_test_*
# STRIPE_PRICE_BASIC="price_..."
# STRIPE_PRICE_DESTAQUE="price_..."
# STRIPE_PRICE_PREMIUM="price_..."

# Google Cloud Vision API (opcional) — OCR para extrair data de nascimento do documento KYC.
# Se definido, o Vision é usado primeiro; em caso de falha ou ausência, usa Tesseract.
# Crie uma chave em: Google Cloud Console > APIs e serviços > Credenciais > Criar credenciais > Chave de API.
# Ative a "Cloud Vision API" no projeto.
# GOOGLE_VISION_API_KEY="sua-chave-api"

# Sentry (opcional) — DSN do projeto para erro/performance na API. Sem DSN, nada é enviado.
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
