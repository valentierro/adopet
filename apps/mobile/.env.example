# URL da API (obrigatório para feed/swipes reais).
# Ver SETUP_EXPO_GO.md para testar com Expo Go no celular.
#
# No celular físico (Expo Go): use o IP do seu Mac na mesma Wi‑Fi, ex.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#   (descubra o IP: ipconfig getifaddr en0)
# No simulador iOS: localhost funciona.
# No emulador Android: o app troca automaticamente localhost por 10.0.2.2 em dev.
EXPO_PUBLIC_API_URL=http://localhost:3000

# ID do usuário (até ter login; deve existir no seed da API)
# EXPO_PUBLIC_USER_ID=11111111-1111-1111-1111-111111111111

# Sentry (opcional): DSN do projeto para crash reporting em produção.
# Configure no EAS (Secrets) como EXPO_PUBLIC_SENTRY_DSN para o ambiente Production.
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
